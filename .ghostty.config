theme = Vague
mouse-hide-while-typing = true
scrollback-limit = 1000000
cursor-style = block
cursor-style-blink = false
cursor-color = #ffffff
cursor-text = #000000

font-family = "MesloLGS NF"

# Shell integration
shell-integration = detect
shell-integration-features = cursor, sudo, title, ssh-env, ssh-terminfo

# Clipboard
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true

# Split visual differentiation
unfocused-split-opacity = 0.75

# Quick terminal
quick-terminal-position = top
quick-terminal-size = 40%
quick-terminal-autohide = true

keybind = global:cmd+grave_accent=toggle_quick_terminal

keybind = ctrl+n=new_window
keybind = cmd+shift+t=new_tab

keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:bottom
keybind = ctrl+shift+k=goto_split:top
keybind = ctrl+shift+l=goto_split:right

keybind = ctrl+a>h=new_split:left
keybind = ctrl+a>j=new_split:down
keybind = ctrl+a>k=new_split:up
keybind = ctrl+a>l=new_split:right
keybind = ctrl+a>f=toggle_split_zoom

# Resize splits
keybind = ctrl+a>ctrl+h=resize_split:left,10
keybind = ctrl+a>ctrl+j=resize_split:down,10
keybind = ctrl+a>ctrl+k=resize_split:up,10
keybind = ctrl+a>ctrl+l=resize_split:right,10

# Equalize splits
keybind = ctrl+a>equal=equalize_splits

keybind = ctrl+a>n=next_tab
keybind = ctrl+a>p=previous_tab

# Jump between prompts (requires shell integration)
keybind = cmd+up=jump_to_prompt:-1
keybind = cmd+down=jump_to_prompt:1

# Font size
keybind = cmd+equal=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+0=reset_font_size

keybind = super+r=reload_config

window-save-state = always
